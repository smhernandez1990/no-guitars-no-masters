<%- include('../partials/_navbar.ejs', { title: gear.name }) %>
<body>
    <%- include('../partials/_pageHeader.ejs', { subheader: `${gear.name}` }) %>
    <div>
        <img src="<%= gear.img %>" alt="Photo of <%= gear.name %>" />
    </div>
    <div>
        Manufactured By: <%= gear.company %>
    </div>
    <div>
        Type: <%= gear.format %>
    </div>
    <div>
        Effect:
        <ul style="list-style-type: none;">
            <% const effects = [gear.effects] %>
            <% effects.forEach(fx => { %>
                <li><%= fx %></li>
            <% }) %>
        </ul>
    </div>
    <div>
        Description: <%= gear.description %>
    </div>
    <div>
        Submitted By: <%= gear.createdBy %>
    </div>
    <div>
        <button onclick="window.history.back()">Go Back</button>
        <% if (user.username === gear.createdBy) { %>
        <a href="/gear/<%= gear._id %>/edit"><button>Edit</button></a> 
        <form action="/gear/<%= gear._id %>?_method=DELETE" method="POST"><button type="submit">Delete</button></form>
        <% } %>
    </div>
</body>
</html>